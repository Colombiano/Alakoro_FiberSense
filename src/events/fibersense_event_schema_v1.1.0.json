{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://alakoro.fibersense/schemas/event-v1.1.0.json",
  "title": "FiberSense Semantic Event Schema",
  "version": "1.1.0",
  "description": "Schema de eventos semânticos para DFOS em poços de petróleo. Inclui 18 event types cobrindo todas as 15 assinaturas canônicas.",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "version",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Identificador único do evento"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "LeakDetected",
        "JouleThomsonSignature",
        "ValveMultipointing",
        "ValveChatter",
        "SluggingCycle",
        "CrossflowDetected",
        "VelocityEstimate",
        "RateEstimate",
        "FIPEstimate",
        "DiagnosisConcluded",
        "CementBondEvaluated",
        "ReCementingAssessed",
        "CementChannelingDetected",
        "FractureScreenoutDetected",
        "WarmBackDetected",
        "PerforationEffectivenessEvaluated",
        "ProppantDistributionMapped",
        "FractureHeightGrowthDetected"
      ],
      "description": "Tipo do evento semântico. 18 tipos cobrindo todas as assinaturas canônicas M15."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp ISO 8601 do evento"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Versão do schema (semver)"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID de correlação para rastreamento de eventos relacionados"
    },
    "source": {
      "type": "string",
      "description": "Fonte do evento (ex: 'AlakoroFiberSense-v2.2.0')"
    },
    "payload": {
      "type": "object",
      "required": [
        "survey_id",
        "well_id"
      ],
      "properties": {
        "survey_id": {
          "type": "string",
          "description": "ID do survey DFOS"
        },
        "survey_phase": {
          "type": "string",
          "enum": [
            "Baseline",
            "AnnulusBleed",
            "ShutIn",
            "Production",
            "Pressurization",
            "WarmBack",
            "StepRateTest",
            "Injection",
            "Perforation",
            "FracStimulation",
            "Cementing",
            "ReCementing"
          ],
          "description": "Fase do survey (SurveyPhaseType)"
        },
        "well_id": {
          "type": "string",
          "description": "Identificador do poço"
        },
        "depth_md": {
          "type": "number",
          "description": "Profundidade medida do evento (m)"
        },
        "component_id": {
          "type": "string",
          "description": "ID do componente (válvula, packer, etc.)"
        },
        "evidence": {
          "type": "array",
          "description": "Evidências que sustentam o evento",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "channel_range": {
                "type": "array",
                "items": {
                  "type": "number"
                }
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "estimates": {
          "type": "array",
          "description": "Estimativas quantitativas derivadas",
          "items": {
            "type": "object",
            "properties": {
              "parameter": {
                "type": "string"
              },
              "value": {
                "type": "number"
              },
              "unit": {
                "type": "string"
              },
              "uncertainty": {
                "type": "number"
              }
            }
          }
        },
        "diagnosis": {
          "type": "object",
          "description": "Diagnóstico consolidado",
          "properties": {
            "severity": {
              "type": "string",
              "enum": [
                "Low",
                "Medium",
                "High",
                "Critical"
              ]
            },
            "recommendation": {
              "type": "string"
            },
            "confidence_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    }
  }
}